{
  "name": "poker-infinity",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @poker/server --filter @poker/web dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:property": "pnpm --filter @poker/engine test:property",
    "db:generate": "pnpm --filter @poker/db db:generate",
    "db:migrate": "pnpm --filter @poker/db db:migrate",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
